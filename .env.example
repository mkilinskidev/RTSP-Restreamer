# Keep this file as an example only. Put real credentials in a local .env file.

# Recommended: keep credentials separate. This avoids RTSP auth failures when
# the password contains special characters such as @, #, :, /, ?, %, or spaces.
CAMERA_RTSP_URL=rtsp://your_ip_address/Streaming/Channels/101
CAMERA_RTSP_USERNAME=username
CAMERA_RTSP_PASSWORD=password

# Optional: some cameras behave differently depending on RTSP User-Agent.
# If VLC works but ffmpeg gets 401, try:
# RTSP_USER_AGENT=LibVLC/3.0.20
RTSP_USER_AGENT=

# gstreamer is recommended for Hikvision-like cameras that return 401 in ffmpeg.
# Use ffmpeg only when you know your camera works with it.
STREAM_BACKEND=gstreamer
GSTREAMER_TRANSCODE=true
GSTREAMER_VIDEO_BITRATE=2500
GSTREAMER_VIDEO_WIDTH=1920
GSTREAMER_VIDEO_HEIGHT=1080
GSTREAMER_VIDEO_FPS=25

FFMPEG_TRANSCODE=false
HLS_SEGMENT_TYPE=mpegts
HLS_SEGMENT_SECONDS=2
HLS_LIST_SIZE=6
FFMPEG_RESTART_SECONDS=5
